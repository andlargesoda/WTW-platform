@startuml

title Онлайн-кинотеатр "Что посмотреть?" - Диаграмма вариантов использования

' Ориентация
'left to right direction
top to bottom direction
skinparam linetype ortho
skinparam packageStyle rectangle

' Пользователи
actor "Незарегистрированный\nпользователь" as Guest
actor "Зарегистрированный\nпользователь" as User
actor "Администратор" as Admin

' Внешние системы
actor "Социальные\nсети\n(VK,\nTelegram,\nOK)" as Social
actor "Почтовый\nсервис" as Mail
actor "Основной\nсайт\nонлайн-кинотеатра" as CoreSite
actor "Рекламная\nсеть" as Ads

' Онлайн-кинотеатр
rectangle "Онлайн-кинотеатр\n«Что посмотреть?»" {

  usecase "UC-1\nРегистрация\nпользователя" as UC_Register
  usecase "UC-2\nАвторизация" as UC_Login
  usecase "UC-3\nАвторизация\nчерез\nсоциальные\nсети" as UC_SocialLogin
  usecase "UC-4\nПодтверждение\ne-mail" as UC_EmailConfirm

  usecase "UC-5\nПоиск\nфильма" as UC_Search
  usecase "UC-6\nПросмотр\nпубличных\nподборок" as UC_ViewPublic

  usecase "UC-7\nСоздание\nподборки" as UC_CreateCollection
  usecase "UC-8\nРедактирование\nподборки" as UC_EditCollection
  usecase "UC-9\nУдаление\nподборки" as UC_DeleteCollection

  usecase "UC-10\nДобавление\nфильма\nв подборку" as UC_AddMovie
  usecase "UC-11\nУдаление\nфильма\nиз подборки" as UC_RemoveMovie
  
  usecase "UC-12\nДобавление\nзаметки" as UC_AddNote
  usecase "UC-13\nРедактирование\nзаметки" as UC_EditNote
  
  usecase "UC-14\nСлучайный\nвыбор фильма" as UC_Random
  
  usecase "UC-15\nМодерация\nподборок" as UC_Moderate
  usecase "UC-16\nБлокировка\nпользователя" as UC_Block
  
  usecase "UC-17\nПоказ\nрекламы" as UC_Ads
}

' Связи пользователей
Guest -- UC_Register
Guest -- UC_Login
Guest -- UC_Search
Guest -- UC_ViewPublic
Guest -- UC_Random

User -- UC_Search
User -- UC_ViewPublic
User -- UC_CreateCollection
User -- UC_EditCollection
User -- UC_DeleteCollection
User -- UC_AddMovie
User -- UC_RemoveMovie
User -- UC_AddNote
User -- UC_EditNote
User -- UC_Random

Admin -- UC_Moderate
Admin -- UC_Block

' Расширения и включения
UC_Login <. UC_SocialLogin : <<extend>>
UC_Register .> UC_EmailConfirm : <<include>>

' Связи внешних систем
UC_SocialLogin --> Social
UC_EmailConfirm --> Mail
UC_Search --> CoreSite
UC_AddMovie --> CoreSite
UC_Ads --> Ads

@enduml